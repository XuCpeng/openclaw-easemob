{
  "name": "@saber3555/openclaw-easemob",
  "version": "1.0.3",
  "description": "Easemob (环信) channel plugin for OpenClaw - A personal AI agent supporting IM integration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "easemob",
    "环信",
    "im",
    "chat",
    "channel"
  ],
  "author": "XuCpeng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/XuCpeng/openclaw-easemob.git"
  },
  "bugs": {
    "url": "https://github.com/XuCpeng/openclaw-easemob/issues"
  },
  "homepage": "https://github.com/XuCpeng/openclaw-easemob#readme",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.9",
    "@vitest/coverage-v8": "^3.0.7",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.7",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.31.0"
}
